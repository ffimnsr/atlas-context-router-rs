# Ignore environment variable files
.env
.codex
.codex/

# Ignore all markdown files except README.md and ISSUES.md
*.md
!README.md
!ISSUES.md
!COMPATIBILITY.md
!SHIPPED.md

# Generated by Cargo will have compiled files and executables
/target/

# Track Cargo.lock because this workspace ships executable atlas-cli.

# These are backup files generated by rustfmt
**/*.rs.bk

# By default, macOS and Linux generate these files, which can be ignored
.DS_Store
*.swp

# By default, Windows generates these files, which can be ignored
Thumbs.db

# Ignore coverage output
coverage/

# Ignore IDE/editor folders
.idea/
.vscode/
*.iml

# Ignore logs
*.log

# Atlas specific ignores
.atlas/
/.github/hooks/atlas-copilot.json


.patches
