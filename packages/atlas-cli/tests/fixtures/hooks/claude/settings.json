{
  "hooks": {
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".atlas/hooks/atlas-hook claude config-change"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".atlas/hooks/atlas-hook claude cwd-changed"
