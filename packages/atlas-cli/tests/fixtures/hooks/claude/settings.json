      {
        "hooks": [
          {
            "type": "command",
            "command": ".atlas/hooks/atlas-hook claude elicitation-result"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".atlas/hooks/atlas-hook claude file-changed"
          }
        ]
      }
