{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-context-router-rs/schemas/atlas_cli.v1/doctor.schema.json",
  "title": "atlas_cli.v1 doctor",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "command", "data"],
  "properties": {
    "schema_version": { "const": "atlas_cli.v1" },
    "command": { "const": "doctor" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "error_code", "message", "suggestions", "checks"],
      "properties": {
        "ok": { "type": "boolean" },
        "error_code": { "type": "string" },
        "message": { "type": "string" },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["check", "ok", "detail", "issue_code"],
            "properties": {
              "check": { "type": "string" },
              "ok": { "type": "boolean" },
              "detail": { "type": "string" },
              "issue_code": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  }
}
